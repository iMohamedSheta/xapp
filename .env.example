# ==============================================================================
# Application Configuration
# ==============================================================================
APP_NAME=xapp
APP_URL=localhost
APP_PORT=8080
APP_BIND_ADDRESS=0.0.0.0
APP_BIND_PORT=8080
APP_API_PREFIX=/api/v1
APP_ENV=dev
APP_DEBUG=true
DEMO_MODE=false
APP_SECRET=hxdCTfhtkyJBVE01k8vvtaMHbzTmr401QqGl1111
APP_GLOBAL_RATE_LIMIT=100-M

# HTTPS Configuration (Optional)
APP_HTTPS_ENABLED=false
APP_HTTPS_CERT=certs/server_local.crt
APP_HTTPS_KEY=certs/server_local.key
APP_HTTPS_PORT=8080

# ==============================================================================
# Database Configuration
# ==============================================================================
DB_CONNECTION=default

# Default PostgreSQL Connection settings
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=xapp
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# Database Pool Settings
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME=30m

# ==============================================================================
# Redis & Cache Configuration
# ==============================================================================
REDIS_DEFAULT=default
REDIS_CLUSTER=redis
REDIS_PREFIX=xapp_

# Default Redis connection (App Cache)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=10
REDIS_DEFAULT_ACTIVE=true
REDIS_POOL_SIZE=0
REDIS_TIMEOUT=

# Queue Redis connection (Asynq background workers)
REDIS_QUEUE_HOST=127.0.0.1
REDIS_QUEUE_PORT=6379
REDIS_QUEUE_PASSWORD=
REDIS_QUEUE_DB=9
REDIS_QUEUE_ACTIVE=true
REDIS_QUEUE_POOL_SIZE=0
REDIS_QUEUE_TIMEOUT=
